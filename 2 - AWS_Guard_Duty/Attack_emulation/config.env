###############################################################################
# Threat Simulation Configuration
# Update these values with your Project 1 infrastructure details
###############################################################################

# AWS Region
AWS_REGION="us-east-1"

# Project 1 Infrastructure Details
BASTION_HOST_IP=""           # Public IP of bastion host
BASTION_KEY_PATH="~/.ssh/bastion-key.pem"

# Private EC2 Instance Details (targets)
PRIVATE_INSTANCE_1_IP=""     # Private IP of first instance
PRIVATE_INSTANCE_2_IP=""     # Private IP of second instance (if exists)
PRIVATE_KEY_PATH="~/.ssh/private-instance-key.pem"

# EC2 Instance IDs (for AWS API calls)
PRIVATE_INSTANCE_1_ID=""
PRIVATE_INSTANCE_2_ID=""

# VPC Details
VPC_ID=""
PRIVATE_SUBNET_1_ID=""
PRIVATE_SUBNET_2_ID=""

# S3 Bucket for testing (create a test bucket or use existing)
TEST_S3_BUCKET=""

# Simulation Settings
SIMULATION_DURATION=300      # Duration in seconds for long-running sims
LOG_DIR="./logs"
VERBOSE=true